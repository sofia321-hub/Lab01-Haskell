-- Evaluación de funciones sobre listas

head [10,20,30,40]

tail [10,20,30,40]

take 3 [1..10]

drop 4 [1..10]

length [1,2,3,4,5]


{-
La expresión [1..10] genera una lista de números desde 1 hasta 10.

Esto se relaciona con la evaluación perezosa porque Haskell puede generar
listas grandes o incluso infinitas calculando solo los elementos
que realmente se necesitan.
-}



-- Funciones solicitadas


-- Devuelve el primer elemento de una lista
primerElemento :: [a] -> a
primerElemento (x:xs) = x


-- Calcula el producto de una lista de forma recursiva
productoLista :: [Int] -> Int
productoLista [] = 1
productoLista (x:xs) = x * productoLista xs


-- Devuelve solo números mayores o iguales a 0
eliminarNegativos :: [Int] -> [Int]
eliminarNegativos [] = []
eliminarNegativos (x:xs)
 | x >= 0 = x : eliminarNegativos xs
 | otherwise = eliminarNegativos xs


-- Invierte una lista sin usar reverse
invertir :: [a] -> [a]
invertir [] = []
invertir (x:xs) = invertir xs ++ [x]
